{
  "name": "@aklinker1/zeta",
  "description": "Composable, testable, OpenAPI-first backend framework with validation built-in",
  "version": "2.1.2",
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.3.5",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "default": "./dist/types.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "default": "./dist/client.mjs"
    },
    "./testing": {
      "types": "./dist/testing.d.mts",
      "default": "./dist/testing.mjs"
    },
    "./schema": {
      "types": "./dist/schema.d.mts",
      "default": "./dist/schema.mjs"
    },
    "./adapters/zod-schema-adapter": {
      "types": "./dist/adapters/zod-schema-adapter.d.mts",
      "default": "./dist/adapters/zod-schema-adapter.mjs"
    },
    "./transports/bun-transport": {
      "types": "./dist/transports/bun-transport.d.mts",
      "default": "./dist/transports/bun-transport.mjs"
    },
    "./transports/fetch-transport": {
      "types": "./dist/transports/fetch-transport.d.mts",
      "default": "./dist/transports/fetch-transport.mjs"
    },
    "./transports/deno-transport": {
      "types": "./dist/transports/deno-transport.d.mts",
      "default": "./dist/transports/deno-transport.mjs"
    }
  },
  "files": [
    "dist/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "url": "https://github.com/aklinker1/zeta"
  },
  "keywords": [
    "backend",
    "server",
    "validation",
    "openapi"
  ],
  "scripts": {
    "dev": "bun test --watch",
    "build": "tsdown src/{index,types,client,testing,schema,adapters/zod-schema-adapter,transports/bun-transport,transports/fetch-transport,transports/deno-transport}.ts",
    "bench": "bun run src/__tests__/bench.ts",
    "example": "bun --watch run example.ts",
    "example:prod": "NODE_ENV=production bun run example",
    "docs:dev": "zola -r docs serve",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0",
    "openapi-types": "^12.1.3",
    "rou3": "^0.7.12",
    "scule": "^1.3.0"
  },
  "devDependencies": {
    "@aklinker1/check": "^2.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/sdk-trace-node": "^2.5.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@types/bun": "latest",
    "@types/deno": "^2.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260202.1",
    "changelogen": "^0.6.2",
    "cookie": "^1.1.1",
    "dedent": "^1.7.1",
    "elysia": "^1.4.19",
    "expect-type": "^1.2.1",
    "hono": "^4.11.2",
    "jsr": "^0.13.5",
    "mermaid": "^11.12.0",
    "oxlint": "^1.2.0",
    "prettier": "^3.5.3",
    "publint": "^0.3.12",
    "tinybench": "^4.0.1",
    "tsdown": "^0.21.2",
    "vitepress": "^2.0.0-alpha.12",
    "vitepress-plugin-mermaid": "^2.0.17",
    "zod": "^4.1.11"
  },
  "peerDependencies": {
    "@types/bun": "*",
    "@types/deno": "*"
  },
  "peerDependenciesMeta": {
    "@types/bun": {
      "optional": true
    },
    "@types/deno": {
      "optional": true
    }
  }
}
